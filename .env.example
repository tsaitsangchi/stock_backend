# ──────────────────────────────────────────────
# .env.example — 環境變數範本（安全分享版 / v6.0.0 對齊 §0.0-I.8）
# ──────────────────────────────────────────────
# 使用方式：
#   1. cp .env.example .env
#   2. 填入下方各欄位的真實值（your_*_here 替換為實際值）
#   3. .env 已被 .gitignore 排除，切勿提交至版本控制
#
# 治權依據：依憲章 §0.0-I.8 .env 環境變數契約清單；
#          14 變數中 7 個為「強制」（缺一即無法啟動 v6.0.0 治權核心），
#          其餘 7 個為「可選」。
#
# 安全注意：
#   - FINMIND_TOKEN 包含個人身份資訊（user_id / email / IP），絕對不可硬編碼或公開
#   - DB_PASSWORD / GEMINI_API_KEY / FRED_API_KEY / GITHUB_TOKEN 同理為機密
#   - 依憲章 §2319：密鑰只能存在於 .env 或受控秘密管理機制中
# ──────────────────────────────────────────────

# ===== Runtime Environment (運行時治權 / §3.2 可選) =====
# 執行環境標記（development / staging / production）
ENV=development

# 日誌層級（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# 時區設定（標準：Asia/Taipei）
TZ=Asia/Taipei

# ===== Bootstrap Anchor (啟動錨點 / §一-0 §2335 強制) =====
# 物理路徑錨點；必須與 path_setup.py 計算之 PROJECT_ROOT_CALC 完全一致
# 修改本機路徑時請同步更新此值
PROJECT_ROOT=/home/your_user/path/to/stock_backend

# ===== Backend Tracking (追蹤主權 / §8 §9.1 可選) =====
# MLflow 追蹤後端 URI（檔案路徑 file://... 或 server URI http://...）
MLFLOW_TRACKING_URI=file:///home/your_user/path/to/stock_backend/models/mlflow

# ===== 1. 資料庫配置 (Database / §6.7 §3.2 全部強制) =====
# PostgreSQL host（本機通常為 localhost）
DB_HOST=localhost

# PostgreSQL port（預設 5432）
DB_PORT=5432

# PostgreSQL database 名稱（v6.0.0 治權核心啟動必要）
DB_NAME=your_db_name_here

# PostgreSQL 使用者（v6.0.0 治權核心啟動必要）
DB_USER=your_db_user_here

# PostgreSQL 密碼（依 §2319 嚴禁寫入程式碼）
DB_PASSWORD=your_db_password_here

# ===== 2. AI 服務 (AI Services / Type-3 可選依賴) =====
# Google Gemini API key（可選；目前非治權核心使用）
GEMINI_API_KEY=your_gemini_api_key_here

# ===== 3. 數據源 API 金鑰 (Data Source APIs / §3.1 §7) =====
# FinMind API Token（從 https://finmindtrade.com 申請；§7 唯一數據主權；JWT 含個人身份資訊）
FINMIND_TOKEN=your_finmind_jwt_token_here

# FRED (St. Louis Fed) API Key（從 https://fredaccount.stlouisfed.org/ 免費申請）
# 用於宏觀指標同步（VIX, Yield Spread, DXY, M2, PMI 等）
FRED_API_KEY=your_fred_api_key_here

# ===== 4. 工具與版本控制 (Tools / Type-3 可選依賴) =====
# GitHub API token（可選；v6.1.0+ ultrareview / PR 自動化所需）
GITHUB_TOKEN=your_github_token_here
