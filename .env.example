# ──────────────────────────────────────────────
# .env.example — 環境變數範本（安全分享版）
# ──────────────────────────────────────────────
# 使用方式：
#   1. cp .env.example .env
#   2. 填入下方各欄位的真實值
#   3. .env 已被 .gitignore 排除，切勿提交至版本控制
#
# 注意：FINMIND_TOKEN 包含個人身份資訊（user_id / email / IP），
#       絕對不可硬編碼在原始碼或上傳至 GitHub / 公開倉庫。
# ──────────────────────────────────────────────

# FinMind API Token（從 https://finmindtrade.com 申請後填入）
FINMIND_TOKEN=your_finmind_jwt_token_here

# FRED (St. Louis Fed) API Key（從 https://fredaccount.stlouisfed.org/ 免費申請）
# 用於 fetch_fred_data.py 抓取美國宏觀指標（VIX, Yield Spread, DXY, M2, PMI 等）
FRED_API_KEY=your_fred_api_key_here

# PostgreSQL 連線設定
DB_PASSWORD=stock
DB_HOST=localhost
DB_PORT=5432
