# 忽略所有 scripts 底下的檔案
*
# 允許進入子目錄
!*/

# 只允許特定的檔案
!/.gitignore
!/README.md
!/requirements.txt
!*.py
!*.txt
!*.sh
!*.md

# 排除備份與大型資料庫
root_legacy_backup/
scripts/archive/
scripts/_patch_backup/
scripts_backup/
mlflow.db
scratch/
.ipynb_checkpoints/
*.pyc
__pycache__/
venv/
.venv/
.env
outputs/
lightning_logs/
*.log

